%%%%%%%%%%% --- Physics / Complex Dynamical Systems --- %%%%%%%%%%
\node[physics_cross] (IM) at (-55,-6) {
\textbf{Ising Model (IM)}\\[4pt]
$p(\bm{x}) \propto \exp\!\left( \sum_i^{n} \mu_i x_i + \sum_{<i,j>} \sigma_{ij} x_i x_j\right)$
};
\node[physics_cross] (CW) at (-37,-9) {
\textbf{Curie-Weiss}
};
\node[physics_cross] (BC) at (-55,9) {
\textbf{Blume-Capel}\\[4pt]
$p(\bm{x}) \propto \text{IM} + \sum_i^{n} \alpha^2 x_i^2$
};
\node[physics_cross] (Potts) at (-60,1) {
\textbf{Potts}\\[4pt]
$x_i \in \{1, 2, 3, .., h\}$
};


\node[physics_time] (cusp) at (-4,11) {
\textbf{Cusp Catastrophe}
};
\node[physics_time] (KIM) at (-47,14) {
\textbf{Kinectic IM}
};
\node[physics_time] (RP/RN) at (-26,-17) {
\textbf{RP $\rightarrow$ RN}
};



%%%%%%%%%%% --- Machine Learning /Statistics --- %%%%%%%%%%
\node[ML_cross] (MRF) at (-55,-22) {
\textbf{MRF}\\[4pt]
$p(\bm{x}) \propto \prod_c \psi_c(\bm{x}_c)$
};
\node[ML_cross] (logistic) at (-30,-6) {
\textbf{Logistic Regression}
};
\node[ML_cross] (GLM) at (-12,-6) {
\textbf{GLM}\\[4pt]
$g(\bm{\eta})=\bm{X}\bm{\beta}$
};
\node[ML_cross] (BN) at (-55,-34) {
\textbf{(D)BN}
};
\node[ML_cross] (HRF) at (-50.5,-34) {
\textbf{HRF}
};
\node[ML_cross] (MGM) at (-46,-20) {
\textbf{MGM}
};
\node[ML_cross] (ETM) at (-42,-17) {
\textbf{Exponential Trace Model}
};
\node[ML_cross] (GGM) at (-26,-22) {
\textbf{GGM}\\[4pt]
${\bm{\Sigma}} = {\bm{K}}^{-1} = \bm{\Delta} (\bm{I} - \bm{\Omega})^{-1} \bm{\Delta}$
};
\node[ML_cross] (LVGGM) at (-16,-27) {
\textbf{LVGGM}
};
\node[ML_cross] (GGIM) at (-18,-31) {
\textbf{GGIM}
};
\node[ML_cross] (cdexGGM) at (-24,-34) {
\textbf{cdexGGM}
};
\node[ML_cross] (latentGGM) at (-19,-36) {
\textbf{latent GGM}
};
\node[ML_cross] (RandomGGM) at (-29,-38) {
\textbf{Random GGM}
};


\node[ML_time] (TD-MRF) at (-46,-30) {
\textbf{TD-MRF}\\[4pt]
$p(\bm{x}) \propto \prod_c \psi_c(\bm{x}_{c}^{t})$
};
\node[ML_time] (DTW) at (-2,-16) {
\textbf{DTW}
};
\node[ML_time] (DHRF) at (-42,-34) {
\textbf{D-HRF}
};
\node[ML_time] (HMM) at (-34,-42) {
\textbf{Hidden Markov Model (HMM)}
};
\node[ML_time] (TVGL) at (-38,-30) {
\textbf{TVGL}
};
\node[ML_time] (LTGL) at (-38,-38) {
\textbf{(L)TGL$_{\kappa/p}$}
};
\node[ML_time] (TAGM) at (-34,-34) {
\textbf{TAGM}
};
\node[ML_time] (DynamicGGM) at (-42,-26) {
\textbf{Dynamic GGM}\\[4pt]
$\bm{\Sigma}^t = \left(\bm{K}^t\right)^{-1}$
};



%%%%%%%%%%% --- Network Psychometrics --- %%%%%%%%%%
\node[network_cross] (OMRF) at (-59,-14) {
\textbf{OMRF}
};
\node[network_cross] (IdiographicIM) at (-43,2) {
\textbf{Idiographic IM}\\[4pt]
$p(\bm{x}) = \sum_{\bm{w}} \overbrace{p(\bm{x} \mid \bm{w})}^{\text {graph coloring }} p(\bm{w})$
};
\node[network_cross] (DCM) at (-30,2) {
\textbf{Divide \& Color}\\[4pt]
$p(\bm{x}) = \sum_{\bm{w}} \overbrace{p(\bm{x} \mid \bm{w})}^{\text {graph coloring }} p(\bm{w})$
};
\node[network_cross] (LNM/RNM) at (-11,-16) {
\textbf{LNM/RNM}
};
\node[network_cross] (EGM) at (-7,-19) {
\textbf{EGM}
};
\node[network_cross] (EGA) at (-11,-19) {
\textbf{EGA}
};
\node[network_cross] (MNM) at (-38,-20) {
\textbf{MNM}
};



\node[network_time] (TD-IM) at (-54,-42) {
\textbf{time-dependent IM}
};
\node[network_time] (multi-VAR) at (-1,-19) {
