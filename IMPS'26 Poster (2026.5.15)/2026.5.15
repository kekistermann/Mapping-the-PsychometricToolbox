%%%%%%%%%%% --- Psychometrics --- %%%%%%%%%%
\node[psychometrics_cross] (E-RM) at (-20,-9) {
\textbf{E-RM}\\[4pt]
$p(\bm{x}) \propto \prod_{i=1}^p \beta_i^{x_i} \lambda_{x_+}$
};
\node[psychometrics_cross] (M-RM) at (-37,-14) {
\textbf{M-RM}
};
\node[psychometrics_cross] (MD-2PLM) at (-46,-14) {
\textbf{MD-2PLM}
};
\node[psychometrics_cross] (NLFM) at (-14,-13) {
\textbf{NLFM}\\[4pt]
$\Rightarrow \bm{\Sigma} = \bm{\Lambda} \bm{\Lambda}^{\top} + \bm{\Psi}$
};
\node[psychometrics_cross] (PA) at (5,10) {
\textbf{Path Analysis}
};
\node[psychometrics_cross] (SEM) at (0,4) {
\textbf{Structural Equation Model (SEM)}\\[4pt]
$\Rightarrow {\bm{\Sigma}}=\bm{\Lambda}(\bm{I}-\bm{B})^{-1} \bm{\Psi}(\bm{I}-\bm{B})^{-1 \top} \bm{\Lambda}^{\top}+\bm{\Theta}$
};


\node[psychometrics_time] (MSEMRS) at (-5,8) {
\textbf{MSEM-RS}
};
\node[psychometrics_time] (uSEM) at (2,-7) {
\textbf{uSEM}
};
\node[psychometrics_time] (DSEM) at (-1,-34) {
\textbf{DSEM}
};
\node[psychometrics_time] (CLPM) at (4,-33) {
\textbf{CLPM}
};
\node[psychometrics_time] (DFM) at (-1,-40) {
\textbf{DFM}
};
\node[psychometrics_time] (P) at (6,-40) {
\textbf{P-Technique}
};
\node[psychometrics_time] (DLCA) at (-12,-38.5) {
\textbf{DLCA}
};
\node[psychometrics_time] (NDLC-SEM) at (-12,-34) {
\textbf{NDLC-SEM}
};



%%%%%%%%%%% --- Graph Theory / Random Graphs / Network Science --- %%%%%%%%%%
\node[Graph_cross] (ERGM) at (-12,2) {
\textbf{ERGM}
};
\node[Graph_cross] (ER) at (-19,9) {
\textbf{Erd\H{o}s--R\'enyi}
};
\node[Graph_cross] (GRG) at (-17,0) {
\textbf{GRG}
};
\node[Graph_cross] (RCM) at (-38,9) {
\textbf{Random Cluster Model}\\[4pt]
$p(\bm{w}) \propto \prod_{i=1}^{n-1} \prod_{j=i+1}^n \theta_{i j}^{w_{i j}}\left(1-\theta_{i j}\right)^{1-w_{i j}} \lambda^{\kappa(\bm{w})}$
};
\node[Graph_cross] (SBM) at (-24,-2) {
\textbf{SBM}
};
\node[Graph_cross] (SIBM) at (-32,-2) {
\textbf{SIBM}
};



\node[Graph_time] (TERGM) at (-12,11) {
\textbf{TERGM}
};



%%%%%%%%%%% --- Econometrics --- %%%%%%%%%%
\node[econometrics] (VAR) at (7,-24) {
\textbf{VAR(1)}\\[4pt]
$\bm{y}_t = \bm{B} \bm{y}_{t-1}+ \bm{\varepsilon}_t$
};
\node[econometrics] (SVAR) at (2,-15) {
\textbf{SVAR}
};
\node[econometrics] (latentVARMA) at (6,-36) {
\textbf{latent VARMA}
};
\node[econometrics] (TAR) at (7,0) {
\textbf{(Hys)TAR}
};
\node[econometrics] (ART) at (5,-5) {
\textbf{ART}
};
\node[econometrics] (DLM) at (10,-42) {
\textbf{DLM}
};
\node[econometrics] (VDAR) at (8,14) {
\textbf{VDAR}
};



